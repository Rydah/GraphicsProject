#version 430 core

//---------------------------------------------------------------------
// Volumetric Ray Marcher — Step 10a (Beer-Lambert core)
//
// One thread per half-res output pixel.
// Reads:  smoke density SSBO (int, 0..u_MaxDensityVal)
//         wall SSBO (int, 1=wall 0=empty)
//         scene depth texture (sampler2D)
// Writes: RGBA16F image  (RGB = accumulated scattered light, A = transmittance)
//---------------------------------------------------------------------
layout(local_size_x = 16, local_size_y = 16) in;

// Output smoke image (half-res)
layout(binding = 0, rgba16f) writeonly uniform image2D u_Output;

// Scene depth from depth-only FBO (full-res, but we sample it)
uniform sampler2D u_DepthTex;
uniform sampler3D u_NoiseTex;

// Smoke density SSBO (int per voxel, 0 = empty, up to u_MaxDensityVal) (changed to float buffer as we are now using smokefeild's density)
layout(std430, binding = 0) readonly buffer SmokeBuf { float smokeDensity[]; };

// Wall SSBO (int per voxel, 1 = solid wall)
layout(std430, binding = 1) readonly buffer WallBuf  { int walls[]; };

// Camera
uniform mat4  u_InvView;
uniform mat4  u_InvProj;
uniform float u_Near;
uniform float u_Far;

// Volume domain
uniform ivec3 u_GridSize;
uniform vec3  u_BoundsMin;
uniform vec3  u_BoundsMax;
uniform float u_VoxelSize;
// // [UPDATE] we should no longer need to use this
// uniform int   u_MaxDensityVal;     // e.g. 64 for flood fill

// Ray march parameters
uniform float u_DensityScale;      // overall density multiplier  (default ~2.0)
uniform float u_SigmaS;            // scattering coefficient
uniform float u_SigmaA;            // absorption coefficient
uniform int   u_PhaseMode;         // 0 = Henyey-Greenstein, 1 = Rayleigh
uniform float u_G;                 // HG asymmetry parameter [-1, 1]
uniform vec3  u_LightDir;          // normalised world-space light direction
uniform vec3  u_LightColor;        // light colour (default white)
uniform float u_Time;

// Step 10b: boundary turbulence controls
uniform float u_EdgeFadeWidth;     // default ~0.3
uniform float u_CurlStrength;      // default ~1.5
uniform float u_NoiseStrength;     // default ~0.9

// // [UPDATE] We will no longer construct based on floodfill parameters
// // Ellipsoid shape (matches FloodFill parameters)
// uniform vec3  u_SeedWorldPos;      // world-space position of the smoke seed
// uniform int   u_MaxSeedVal;        // ellipsoid Y semi-axis in voxels
// uniform float u_RadiusXZ;          // horizontal scale relative to Y
// uniform float u_RadiusY;           // vertical scale (base)

// Texture output size (half-res dimensions)
uniform ivec2 u_TexSize;

//---------------------------------------------------------------------
// Helpers
//---------------------------------------------------------------------
int flatIdx(ivec3 c) {
    return c.x + c.y * u_GridSize.x + c.z * u_GridSize.x * u_GridSize.y;
}

bool inBounds(ivec3 c) {
    return all(greaterThanEqual(c, ivec3(0))) && all(lessThan(c, u_GridSize));
}

// Trilinear sample of integer SSBO, returns normalised density [0,1]
float sampleSmoke(vec3 worldPos) {
    vec3 gc = (worldPos - u_BoundsMin) / u_VoxelSize - 0.5;
    ivec3 c0 = ivec3(floor(gc));
    ivec3 c1 = c0 + 1;
    vec3  t  = fract(gc);

    // Clamp to grid
    c0 = clamp(c0, ivec3(0), u_GridSize - 1);
    c1 = clamp(c1, ivec3(0), u_GridSize - 1);

    // 8-corner fetch
    // float v000 = float(smokeDensity[flatIdx(ivec3(c0.x, c0.y, c0.z))]);
    // float v100 = float(smokeDensity[flatIdx(ivec3(c1.x, c0.y, c0.z))]);
    // float v010 = float(smokeDensity[flatIdx(ivec3(c0.x, c1.y, c0.z))]);
    // float v110 = float(smokeDensity[flatIdx(ivec3(c1.x, c1.y, c0.z))]);
    // float v001 = float(smokeDensity[flatIdx(ivec3(c0.x, c0.y, c1.z))]);
    // float v101 = float(smokeDensity[flatIdx(ivec3(c1.x, c0.y, c1.z))]);
    // float v011 = float(smokeDensity[flatIdx(ivec3(c0.x, c1.y, c1.z))]);
    // float v111 = float(smokeDensity[flatIdx(ivec3(c1.x, c1.y, c1.z))]);
    float v000 = smokeDensity[flatIdx(ivec3(c0.x, c0.y, c0.z))];
    float v100 = smokeDensity[flatIdx(ivec3(c1.x, c0.y, c0.z))];
    float v010 = smokeDensity[flatIdx(ivec3(c0.x, c1.y, c0.z))];
    float v110 = smokeDensity[flatIdx(ivec3(c1.x, c1.y, c0.z))];
    float v001 = smokeDensity[flatIdx(ivec3(c0.x, c0.y, c1.z))];
    float v101 = smokeDensity[flatIdx(ivec3(c1.x, c0.y, c1.z))];
    float v011 = smokeDensity[flatIdx(ivec3(c0.x, c1.y, c1.z))];
    float v111 = smokeDensity[flatIdx(ivec3(c1.x, c1.y, c1.z))];

    // Trilinear interpolation
    float val = mix(
        mix(mix(v000, v100, t.x), mix(v010, v110, t.x), t.y),
        mix(mix(v001, v101, t.x), mix(v011, v111, t.x), t.y),
        t.z
    );

    // return val / float(max(u_MaxDensityVal, 1));
    return val;
}

// World position to normalized volume UVW (0..1 inside domain)
vec3 worldToVolumeUVW(vec3 worldPos) {
    vec3 extent = max(u_BoundsMax - u_BoundsMin, vec3(1e-5));
    return (worldPos - u_BoundsMin) / extent;
}

// Linearize depth from [0,1] depth buffer value to view-space distance
float linearizeDepth(float d) {
    float z_ndc = d * 2.0 - 1.0;
    return (2.0 * u_Near * u_Far) / (u_Far + u_Near - z_ndc * (u_Far - u_Near));
}

// Ray-AABB slab test. Returns (tEnter, tExit). If tExit < tEnter, no hit.
vec2 rayAABB(vec3 origin, vec3 invDir, vec3 bmin, vec3 bmax) {
    vec3 t1 = (bmin - origin) * invDir;
    vec3 t2 = (bmax - origin) * invDir;
    vec3 tMin = min(t1, t2);
    vec3 tMax = max(t1, t2);
    float tEnter = max(max(tMin.x, tMin.y), tMin.z);
    float tExit  = min(min(tMax.x, tMax.y), tMax.z);
    return vec2(tEnter, tExit);
}

//---------------------------------------------------------------------
// Phase functions
//---------------------------------------------------------------------

// Henyey-Greenstein phase function.
// cosT: dot(rayDir, lightDir). g=0 isotropic, g>0 forward, g<0 back.
float phaseHG(float cosT, float g) {
    float g2    = g * g;
    float denom = max(1.0 + g2 - 2.0 * g * cosT, 1e-5);
    return (1.0 - g2) / (4.0 * 3.14159265 * pow(denom, 1.5));
}

// Rayleigh phase function. Two symmetric lobes (front + back).
float phaseRayleigh(float cosT) {
    return (3.0 / (16.0 * 3.14159265)) * (1.0 + cosT * cosT);
}

//---------------------------------------------------------------------
// Shadow ray: 8 steps toward u_LightDir from worldPos.
// Returns Beer-Lambert transmittance [0, 1].
//---------------------------------------------------------------------
float shadowMarch(vec3 worldPos) {
    float shadowStep = u_VoxelSize * 1.0;
    float shadowT    = 1.0;
    float sigmaE     = u_SigmaS + u_SigmaA;
    vec3  sPos       = worldPos;

    for (int s = 0; s < 16; s++) {
        sPos += u_LightDir * shadowStep;
        vec3  gc = (sPos - u_BoundsMin) / u_VoxelSize - 0.5;
        ivec3 c  = ivec3(floor(gc));
        if (!inBounds(c)) break;
        float sd = sampleSmoke(sPos);
        shadowT *= exp(-sd * sigmaE * shadowStep);
    }
    return shadowT;
}

//---------------------------------------------------------------------
// Main
//---------------------------------------------------------------------
void main() {
    ivec2 px = ivec2(gl_GlobalInvocationID.xy);
    if (px.x >= u_TexSize.x || px.y >= u_TexSize.y) return;

    // Reconstruct ray from camera matrices
    vec2 uv  = (vec2(px) + 0.5) / vec2(u_TexSize);
    vec2 ndc = uv * 2.0 - 1.0;

    vec4 vDir = u_InvProj * vec4(ndc, -1.0, 1.0);
    vDir.w = 0.0;
    vec3 rayDir    = normalize((u_InvView * vDir).xyz);
    vec3 rayOrigin = u_InvView[3].xyz;

    // Ray-AABB intersection with the smoke volume
    vec3 invDir = 1.0 / rayDir;
    vec2 tHit   = rayAABB(rayOrigin, invDir, u_BoundsMin, u_BoundsMax);

    if (tHit.y < 0.0 || tHit.x > tHit.y) {
        imageStore(u_Output, px, vec4(0.0, 0.0, 0.0, 1.0));
        return;
    }

    tHit.x = max(tHit.x, 0.0);

    // Depth clipping: clamp tMax to scene depth so smoke stays behind geometry
    vec2 depthUV    = uv;
    float rawDepth  = texture(u_DepthTex, depthUV).r;
    float sceneZ    = linearizeDepth(rawDepth);
    // Convert linear depth to ray t: approximate using dot product with forward
    vec3 camForward = -normalize(u_InvView[2].xyz);
    float cosAngle  = max(dot(rayDir, camForward), 0.001);
    float maxT      = sceneZ / cosAngle;

    // Always clip — linearizeDepth(1.0) returns far plane so sky pixels are safe
    tHit.y = min(tHit.y, maxT);

    if (tHit.x >= tHit.y) {
        imageStore(u_Output, px, vec4(0.0, 0.0, 0.0, 1.0));
        return;
    }

    // ---- Phase 1: Coarse skip (2x voxelSize steps) ----
    float coarseStep = u_VoxelSize * 2.0;
    float fineStep   = u_VoxelSize * 0.5;
    float t = tHit.x;
    bool foundSmoke = false;
    float segmentLen = max(tHit.y - tHit.x, 0.0);

    // Adaptive budget from segment length (with safe caps)
    int maxCoarseSteps = clamp(int(ceil(segmentLen / coarseStep)) + 2, 1, 1024);

    for (int i = 0; i < maxCoarseSteps; i++) {
        if (t >= tHit.y) break;
        vec3 pos = rayOrigin + rayDir * t;
        float d  = sampleSmoke(pos);
        if (d > 0.002) {
            // Step back one coarse step to not miss the boundary
            t = max(t - coarseStep, tHit.x);
            foundSmoke = true;
            break;
        }
        t += coarseStep;
    }

    if (!foundSmoke) {
        imageStore(u_Output, px, vec4(0.0, 0.0, 0.0, 1.0));
        return;
    }

    // ---- Phase 2: Fine accumulation (Beer-Lambert) ----
    vec3  color         = vec3(0.0);
    float transmittance = 1.0;
    int maxFineSteps = clamp(int(ceil(max(tHit.y - t, 0.0) / fineStep)) + 2, 1, 4096);

    for (int i = 0; i < maxFineSteps; i++) {
        if (t >= tHit.y) break;

        vec3 pos = rayOrigin + rayDir * t;

        // // [UPDATE] We are no longer going to rebuild from scratch
        // // Skip voxels the flood fill never reached.
        // float floodVal = sampleSmoke(pos);
        // if (floodVal <= 0.001) { t += fineStep; continue; }

        // // Euclidean ellipsoid distance [0=centre, 1=surface].
        // vec3 seedToPos = pos - u_SeedWorldPos;
        // float invVS = 1.0 / max(u_VoxelSize, 1e-5);
        // float ex = (seedToPos.x * invVS) / (float(u_MaxSeedVal) * u_RadiusXZ);
        // float ey = (seedToPos.y * invVS) / (float(u_MaxSeedVal) * u_RadiusY);
        // float ez = (seedToPos.z * invVS) / (float(u_MaxSeedVal) * u_RadiusXZ);
        // float ellipDist = sqrt(ex*ex + ey*ey + ez*ez);

        // // Path-based distance: voxels reached via long wall detours (e.g. through
        // // a doorway) spent most of their flood budget on the path and arrive with
        // // a low floodVal. Mapping that back to [0,1] naturally suppresses them.
        // float voxelDist = 1.0 - floodVal;  // 0 at seed, ~1 at barely-reached voxels

        // // Use the worse of the two distances. In open space ellipDist dominates
        // // (giving a perfect sphere). Doorway leakage is suppressed by voxelDist.
        // float combinedDist = max(ellipDist, voxelDist);
        // if (combinedDist >= 1.0) { t += fineStep; continue; }

        // // rawDensity: 1 at the seed centre, 0 at the combined boundary
        // float rawDensity = 1.0 - combinedDist;

        float baseDensity = sampleSmoke(pos);
        if (baseDensity <= 0.001) {
            t += fineStep;
            continue;
        }

        // --- HZD-style Perlin + Worley erosion ---
        vec3 noiseUVW = worldToVolumeUVW(pos)
                      + vec3(u_Time * 0.0025, u_Time * 0.0012, u_Time * -0.0018);

        float worleyCoarse = texture(u_NoiseTex, fract(noiseUVW)).r;
        float worleyFine   = texture(u_NoiseTex, fract(noiseUVW * 4.0 + vec3(0.37, 0.51, 0.29))).r;
        float worleyMicro  = texture(u_NoiseTex, fract(noiseUVW * 12.0 + vec3(0.73, 0.19, 0.61))).r;

        float worleyDetail = worleyCoarse * 0.5 + worleyFine * 0.35 + worleyMicro * 0.15;
        worleyDetail = clamp(worleyDetail, 0.0, 1.0);

        // HZD remap for the solid core
        float erosion = clamp((baseDensity - (1.0 - worleyDetail)) / worleyDetail, 0.0, 1.0);

        // At the boundary (low baseDensity) the remap collapses everything to 0,
        // making the outermost voxel layer vanish uniformly as a hard voxel face.
        // Fix: blend between two modes based on how deep we are in the smoke:
        //   boundary (baseDensity < 0.25) -> baseDensity * worleyDetail
        //     Worley directly shapes whatever thin density is there into puffs.
        //   core (baseDensity > 0.5)      -> HZD erosion remap
        //     Solid interior with carved puff surfaces.
        float boundaryShape = baseDensity * worleyDetail;
        float coreWeight    = smoothstep(0.0, 0.5, baseDensity);
        // Clamp mix factor to [0,1] — mix() extrapolates when t>1 which drives
        // shapedDensity negative and makes the smoke disappear entirely.
        // noiseStrength > 1 instead sharpens the erosion value itself before blending.
        float sharpenedErosion = pow(erosion, 1.0 / max(u_NoiseStrength, 0.001));
        float shapedDensity = mix(boundaryShape, sharpenedErosion, clamp(coreWeight, 0.0, 1.0));
        float density = shapedDensity * u_DensityScale;


        if (density > 0.001) {
            float sigmaE = u_SigmaS + u_SigmaA;

            // Shadow ray: Beer-Lambert transmittance toward the light
            float shadowT = shadowMarch(pos);

            // Powder effect: 0 at thin edges, 1 at dense core.
            // lightMult in [1, 2]: edges stay at least 1x lit, dense core up to 2x.
            float powder    = 1.0 - exp(-density * sigmaE * fineStep * 2.0);
            float lightMult = 1.0 + powder * 0.5;

            // Phase function: angular scattering distribution.
            // Multiply by 4*pi so isotropic (g=0) gives 1.0, matching old Li scale.
            float cosTheta = dot(rayDir, u_LightDir);
            float phase;
            if (u_PhaseMode == 0) {
                phase = phaseHG(cosTheta, u_G);
            } else {
                phase = phaseRayleigh(cosTheta);
            }
            phase *= 4.0 * 3.14159265;

            // Incoming radiance at this sample (direct + ambient sky)
            vec3 ambientLight = vec3(0.25, 0.27, 0.30); // cool blue-grey sky
            vec3 Li = u_LightColor * shadowT * lightMult * phase + ambientLight;

            // Single-scatter accumulation + Beer-Lambert extinction
            color         += transmittance * u_SigmaS * density * Li * fineStep;
            transmittance *= exp(-sigmaE * density * fineStep);

            if (transmittance < 0.01) break;
        }

        t += fineStep;
    }

    imageStore(u_Output, px, vec4(color, transmittance));
}
